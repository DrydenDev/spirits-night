// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource supabase {
  provider = "postgres"
  url      = env("DATABASE_URL")
}

model Spirit {
  id    String    @id @default(uuid())
  name  String    @unique
  slug  String    @unique
  expansion  String
  complexity String
  complexityValue Int @map("complexity_value")
  incarna    Boolean @default(false)
}