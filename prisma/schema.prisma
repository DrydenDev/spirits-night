// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource supabase {
  provider = "postgres"
  url      = env("DATABASE_URL")
}

model Spirit {
  id              String  @id @default(uuid())
  name            String  @unique
  slug            String  @unique
  playstyle       String?
  expansion       String
  complexity      String
  complexityValue Int     @map("complexity_value")
  incarna         Boolean @default(false)
  offense         Int     @default(0)
  control         Int     @default(0)
  fear            Int     @default(0)
  defense         Int     @default(0)
  utility         Int     @default(0)
}

model Adversary {
  id                String   @id @default(uuid())
  name              String   @unique
  expansion         String
  slug              String   @unique
  difficulty        Int
  lossCondition     Json?    @map("loss_condition")
  escalationAbility Json     @map("escalation_ability")
  levels            AdversaryLevel[]
  references        AdversaryReference[]
}

model AdversaryLevel {
  id          String    @id @default(uuid())
  adversaryId String    @map("adversary_id")
  adversary   Adversary @relation(fields: [adversaryId], references: [id])
  level       Int
  difficulty  Int
  title       String
  fearCards   String    @map("fear_cards")
  description String
  @@unique([adversaryId, title], name: "adversaryTitle")
}

model AdversaryReference {
  id          String    @id @default(uuid())
  adversaryId String    @map("adversary_id")
  adversary   Adversary @relation(fields: [adversaryId], references: [id])
  title       String
  level       Int
  maxLevel    Int?      @map("max_level")
  type        String
  phase       String
  description String
}