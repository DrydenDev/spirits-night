// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource supabase {
  provider = "postgres"
  url      = env("DATABASE_URL")
}

model Spirit {
  id    String    @id @default(uuid())
  name  String    @unique
  slug  String    @unique
  expansion  String
  complexity String
  complexityValue Int @map("complexity_value")
  incarna    Boolean @default(false)
}

model Adversary {
  id                String   @id @default(uuid())
  name              String   @unique
  expansion         String
  slug              String   @unique
  difficulty        Int
  lossCondition     Json?    @map("loss_condition")
  escalationAbility Json     @map("escalation_ability")
  levels            AdversaryLevel[]
}

model AdversaryLevel {
  id          String    @id @default(uuid())
  adversaryId String    @map("adversary_id")
  adversary   Adversary @relation(fields: [adversaryId], references: [id])
  level       Int
  difficulty  Int
  title       String
  fearCards   String    @map("fear_cards")
  description String
  @@unique([adversaryId, title], name: "adversaryTitle")
}